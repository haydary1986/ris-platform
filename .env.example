# ---------------------------------------------------------------------------
# RIS Platform — environment variables
#
# Copy to .env.local for local dev (never commit). For production, define
# these in Coolify -> Application -> Environment Variables. Variables
# prefixed with NEXT_PUBLIC_ are exposed to the browser bundle; everything
# else stays server-side. Treat SUPABASE_SERVICE_ROLE_KEY and SENTRY_AUTH_TOKEN
# as secrets.
# ---------------------------------------------------------------------------

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Supabase ---
# Cloud: from project Settings -> API. Self-hosted: from Coolify Supabase template.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Sentry ---
# Public DSN is safe to expose. Auth token only used at build time for source maps.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Optional: ORCID OAuth (Task 104 / FIX-27) ---
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# --- Optional: Scopus (Task 141 / FIX-28) ---
SCOPUS_API_KEY=
