{
  "manifest_version": 3,
  "name": "RIS Scholar Importer",
  "short_name": "RIS Scholar",
  "version": "1.0.0",
  "description": "Export your Google Scholar publications as a .mrhenc file ready to upload to RIS.",
  "action": {
    "default_title": "Export Scholar publications to RIS",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "downloads", "scripting"],
  "host_permissions": ["https://scholar.google.com/*"],
  "background": { "service_worker": "service-worker.js" },
  "content_scripts": [
    {
      "matches": ["https://scholar.google.com/citations*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
